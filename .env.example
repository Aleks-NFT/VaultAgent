# ============================================================
# VaultAgent — Environment Variables
# Copy to .env and fill in values. NEVER commit .env to git.
# ============================================================

# ── RPC Endpoints (Alchemy recommended) ─────────────────────
MAINNET_RPC_URL=https://eth-mainnet.g.alchemy.com/v2/YOUR_ALCHEMY_KEY
SEPOLIA_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR_ALCHEMY_KEY

# ── Deployer Wallet (without 0x prefix) ─────────────────────
# Use a FRESH wallet. Never reuse a compromised one.
PRIVATE_KEY=your_private_key_here

# ── Fee Configuration ────────────────────────────────────────
# Address that receives 0.25% fees from every transaction
# Use your NEW wallet address (not the deployer if separate)
FEE_RECIPIENT=0xYOUR_NEW_WALLET_ADDRESS

# ── Deployed Contract ────────────────────────────────────────
# Set after deploy. Enables write tools in MCP server.
FEE_WRAPPER_ADDRESS=

# ── Etherscan (for contract verification) ───────────────────
ETHERSCAN_API_KEY=your_etherscan_api_key

# ── MCP Server (write tools executor) ───────────────────────
# Private key of wallet that signs execute_* transactions
# Can be same as PRIVATE_KEY or a separate hot wallet
EXECUTOR_PRIVATE_KEY=your_executor_private_key_here

ETH_RPC_URL=${MAINNET_RPC_URL}
