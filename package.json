{
  "name": "vaultagent",
  "version": "0.2.0",
  "description": "First execution-grade MCP server for NFT vault liquidity. Starting with NFTX. Ready for Flayer.",
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspace=packages/mcp-server",
    "build": "echo build-skipped",
    "start": "npx tsx http-server.ts",
    "typecheck": "npm run typecheck --workspace=packages/mcp-server",
    "compile": "npx hardhat compile",
    "deploy:sepolia": "npx hardhat run scripts/deploy.ts --network sepolia",
    "deploy:mainnet": "npx hardhat run scripts/deploy.ts --network mainnet"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-toolbox-viem": "^5.0.3",
    "@tailwindcss/postcss": "^4.2.2",
    "@types/node": "^22.19.15",
    "dotenv": "^17.3.1",
    "ethers": "^6.16.0",
    "hardhat": "^3.1.12",
    "postcss": "^8.5.8",
    "tailwindcss": "^4.2.2",
    "typescript": "~5.8.0",
    "viem": "^2.47.2"
  },
  "dependencies": {
    "node-fetch": "^3.3.2",
    "node-telegram-bot-api": "^0.67.0",
    "zod": "^3.25.76"
  },
  "keywords": [
    "mcp",
    "nftx",
    "nft",
    "liquidity",
    "web3",
    "defi",
    "ethereum",
    "ai-agent",
    "model-context-protocol"
  ],
  "author": "Aleks-NFT",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Aleks-NFT/VaultAgent.git"
  },
  "homepage": "https://github.com/Aleks-NFT/VaultAgent#readme",
  "bugs": {
    "url": "https://github.com/Aleks-NFT/VaultAgent/issues"
  },
  "main": "index.js",
  "directories": {
    "doc": "docs",
    "test": "test"
  }
}
